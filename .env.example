# ── Telegram ────────────────────────────────────────────────────────────────
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── Channels (preferred: numbered pairs — add as many as you like) ───────────
# YouTube playlist ID  →  Telegram channel username (WITHOUT the @ sign)
# _NAME is optional and only used for the state-file names / logs.

CHANNEL_1_NAME=music
CHANNEL_1_PLAYLIST=your_youtube_playlist_id
CHANNEL_1_TELEGRAM=your_channel_username_without_at

CHANNEL_2_NAME=baiba
CHANNEL_2_PLAYLIST=your_second_playlist_id
CHANNEL_2_TELEGRAM=your_second_channel_without_at

# Add CHANNEL_3_*, CHANNEL_4_* … to monitor more channels — no code changes needed.

# ── Legacy channel format (still supported, used only if no CHANNEL_N_* set) ──
# PLAYLIST_ANDREY=your_youtube_playlist_id_for_andrey
# TELEGRAM_CHANNEL_ANDREY=your_channel_username_without_at
# PLAYLIST_BAYBA=your_youtube_playlist_id_for_bayba
# TELEGRAM_CHANNEL_BAYBA=your_channel_username_without_at

# ── Optional ─────────────────────────────────────────────────────────────────
# Your personal Telegram chat ID — bot will send a run summary here
# Get it from @userinfobot
ADMIN_CHAT_ID=

# Path to a Netscape-format cookies file exported from your browser.
# Required only when running on cloud CI (GitHub Actions) to bypass
# YouTube's bot-detection. Leave empty for local runs.
YOUTUBE_COOKIES_FILE=

# Explicit path to ffmpeg binary. Leave empty — the bot auto-discovers ffmpeg
# from PATH and from the ffmpeg-downloader bundle automatically.
# Use only if you have a custom ffmpeg location.
FFMPEG_PATH=

# IMPORTANT on Windows: use an ASCII-only path (no Cyrillic / spaces) to
# avoid ffmpeg encoding errors. Example: C:\Temp\music_bot
DOWNLOAD_DIR=C:\Temp\music_bot

# Tuning
RETRY_ATTEMPTS=3
RETRY_DELAY=5
POST_DELAY=2
LOG_LEVEL=INFO
LOG_FILE=bot.log
