# Telegram Bot
TELEGRAM_TOKEN=your_telegram_bot_token_here

# YouTube Data API v3
YOUTUBE_API_KEY=your_youtube_api_key_here

# Channel pair: Andrey
PLAYLIST_ANDREY=your_youtube_playlist_id_for_andrey
TELEGRAM_CHANNEL_ANDREY=@andrey_channel_username_or_chat_id

# Channel pair: Bayba
PLAYLIST_BAYBA=your_youtube_playlist_id_for_bayba
TELEGRAM_CHANNEL_BAYBA=@bayba_channel_username_or_chat_id

# Optional
RETRY_ATTEMPTS=3
RETRY_DELAY=5
POST_DELAY=1
LOG_LEVEL=INFO
LOG_FILE=bot.log
